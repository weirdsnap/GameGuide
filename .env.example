# 选择你要使用的 LLM 提供商，填入对应的 API Key
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：使用兼容 OpenAI API 的其他服务（如 DashScope、SiliconFlow、DeepSeek 等）
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# HuggingFace 镜像设置（向量库构建时用）
# 国内推荐使用 hf-mirror.com 加速模型下载
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1
# 模型已缓存时跳过联网检查（避免镜像站 API 超时）
HF_HUB_OFFLINE=1
